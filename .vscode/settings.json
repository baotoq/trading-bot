{
    // Step-into (F11) skips functions whose names start with any of these crate
    // prefixes — i.e. std, the async runtime, HTTP, and our deps. Anything that
    // doesn't match (mainly trading_bot:: ...) is fair game to step into.
    "lldb.launch.preRunCommands": [
        "settings set target.process.thread.step-avoid-regexp 'std::|core::|alloc::'",
        "settings set target.process.thread.step-in-avoid-nodebug true",
        "settings set target.process.thread.step-out-avoid-nodebug true"
    ],

    // Only stop the debugger on Rust source files.
    "lldb.launch.sourceLanguages": ["rust"],

    // If source isn't available (e.g. a dep with no debug info), don't pop into disassembly.
    "lldb.showDisassembly": "never",

    // Tame rust-analyzer's auto-imports while we're learning what each crate provides.
    "rust-analyzer.imports.granularity.group": "module",
    "rust-analyzer.check.command": "clippy"
}
