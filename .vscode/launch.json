{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug tradingbot (local)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/app/tradingbot/cmd/server",
      "args": ["-conf", "${workspaceFolder}/app/tradingbot/configs"]
    },
    {
      "name": "Attach to tradingbot in k8s",
      "type": "go",
      "request": "attach",
      "mode": "remote",
      "debugAdapter": "legacy",
      "host": "127.0.0.1",
      "port": 2345
    }
  ]
}
