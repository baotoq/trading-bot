# Normalize line endings to LF on commit
* text=auto eol=lf

# Go source files
*.go text eol=lf
go.mod text eol=lf
go.sum text eol=lf

# TypeScript / JavaScript
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf

# Web
*.html text eol=lf
*.svg text eol=lf

# Config
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.sh text eol=lf

# Binary files — no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# SQLite — binary
*.db binary
*.db-shm binary
*.db-wal binary

# Go diffs — use Go-aware diff driver
*.go diff=golang
